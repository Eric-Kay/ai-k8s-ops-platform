{
    "title": "AI Kubernetes Operations Platform Dashboard",
    "schemaVersion": 38,
    "version": 1,
    "panels": [
        {
            "type": "stat",
            "title": "Service Availability",
            "targets": [
                {
                    "expr": "up"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Pod CPU Usage",
            "targets": [
                {
                    "expr": "sum(rate(container_cpu_usage_seconds_total[5m])) by (pod)"
                }
            ]
        },
        {
            "type": "timeseries",
            "title": "Pod Memory Usage",
            "targets": [
                {
                    "expr": "sum(container_memory_usage_bytes) by (pod)"
                }
            ]
        }
    ]
}